{
  "name": "@queryclear/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env DATABASE_URL=postgresql://queryclear:queryclear@localhost:5432/queryclear prisma validate --schema prisma/schema.prisma",
    "typecheck": "cross-env DATABASE_URL=postgresql://queryclear:queryclear@localhost:5432/queryclear prisma validate --schema prisma/schema.prisma",
    "generate": "prisma generate --schema prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
