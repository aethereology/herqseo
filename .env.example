DATABASE_URL="postgresql://queryclear:queryclear@localhost:5432/queryclear"
APP_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-generated-secret"
AUTH_TRUST_HOST="true"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
AGENT_RUNTIME_URL="http://localhost:8080"
# Agent runtime (services/agent-runtime). Leave OPENAI_API_KEY / WORDPRESS_* unset
# to run the FastAPI service in offline demo mode (fakes), clickable end to end:
#   uvicorn queryclear_agent_runtime.serve:build_app --factory --port 8080
QUERYCLEAR_TOKEN_BUDGET="1000000"
# Used by the runtime to encrypt saved CMS credentials. Set a long random value in production.
QUERYCLEAR_SECRET_KEY="replace-with-a-long-random-secret"
# Optional per-task model routing. Format: provider:model. Defaults preserve the
# original OpenAI path; set Anthropic routes only when ANTHROPIC_API_KEY is set.
QUERYCLEAR_MODEL_ROUTE_CLASSIFICATION="openai:gpt-4.1-mini"
QUERYCLEAR_MODEL_ROUTE_MONITORING="openai:gpt-4.1-mini"
QUERYCLEAR_MODEL_ROUTE_CONTENT_GENERATION="openai:gpt-4.1"
# Phase 1 monitoring set. Comma-separated; allowed values match packages/shared AI_ENGINES.
QUERYCLEAR_MONITORING_ENGINES="chatgpt,google_ai_overviews,google_ai_mode,gemini,perplexity"
# ClaudeAgentRuntime (agent runs via POST /agents/{id}/run). Needs the ``agent``
# extra (pip install -e ".[agent]") + ANTHROPIC_API_KEY; without them agent runs
# use the offline demo session. The reservation is the pre-run budget hold per run.
QUERYCLEAR_AGENT_MODEL="claude-sonnet-4-6"
QUERYCLEAR_AGENT_MAX_TURNS="12"
QUERYCLEAR_AGENT_RESERVE_INPUT_TOKENS="150000"
QUERYCLEAR_AGENT_RESERVE_OUTPUT_TOKENS="50000"
WORDPRESS_BASE_URL=""
WORDPRESS_USERNAME=""
WORDPRESS_APP_PASSWORD=""
QUERYCLEAR_DEV_USER_EMAIL="operator@queryclear.dev"
QUERYCLEAR_DEV_LOGIN_CODE="queryclear-dev"
QUERYCLEAR_DEV_USER_ID="user_dev_owner"
QUERYCLEAR_DEV_USER_ROLE="owner"
QUERYCLEAR_DEV_ORG_ID="org_dev_queryclear"
QUERYCLEAR_DEV_ORG_NAME="QueryClear Demo"
QUERYCLEAR_DEV_PLAN_TIER="operator"
QUERYCLEAR_DEV_TOKEN_USED="0"
QUERYCLEAR_DEV_DOMAIN_ID="domain_dev_queryclear"
QUERYCLEAR_DEV_DOMAIN_URL="https://example-b2b-saas.com"
QUERYCLEAR_DEV_CMS_TYPE="wordpress"
QUERYCLEAR_DEV_AUTONOMY_MODE="review"
QUERYCLEAR_DEV_DOMAIN_STATUS="onboarding"
