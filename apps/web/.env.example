# Copy to apps/web/.env.local and fill in. Next.js reads env from THIS folder,
# not the repo root. Required: AUTH_SECRET (Auth.js errors without it).
# Generate one with:  openssl rand -base64 32

AUTH_SECRET=""
AUTH_TRUST_HOST="true"
AGENT_RUNTIME_URL="http://localhost:8080"

# Dev sign-in (credentials provider). Defaults exist in auth.ts; override here.
QUERYCLEAR_DEV_USER_EMAIL="operator@queryclear.dev"
QUERYCLEAR_DEV_LOGIN_CODE="queryclear-dev"
QUERYCLEAR_DEV_ORG_NAME="QueryClear Demo"
QUERYCLEAR_DEV_DOMAIN_URL="https://queryclear.com"
